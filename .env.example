# Server Configuration
PORT=4343
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info

# API Keys (optional)
# API_KEY=your-api-key-here

# External Service Timeouts (milliseconds)
REQUEST_TIMEOUT=30000
